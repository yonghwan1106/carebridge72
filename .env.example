# ============================================================
#  케어브릿지 72 - 환경변수 예시
# ------------------------------------------------------------
#  이 파일을 복사해 .env.local 로 저장하세요.
#    cp .env.example .env.local
#
#  ANTHROPIC_API_KEY 가 있으면 → 실제 Claude API 로 분석합니다.
#  키가 없거나 호출이 실패하면 → 데이터셋 기반 폴백 엔진으로
#  자동 전환되어 키 없이도 데모가 100% 작동합니다. (하이브리드)
# ============================================================

# (선택) Anthropic API 키. 비워두면 폴백 엔진으로 작동합니다.
ANTHROPIC_API_KEY=

# (선택) 사용할 모델. 기본값 claude-haiku-4-5-20251001 (속도·안정성 우선)
#  - 비용/속도:  claude-haiku-4-5-20251001  (기본, 데모 권장)
#  - 품질 우선:  claude-sonnet-4-6
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
